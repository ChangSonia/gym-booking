# ═══════════════════════════════════════════════════════════
#  環境變數範本
#
#  1. 複製這個檔案，改名成 .env.local
#  2. 把值填進去
#  3. .env.local 絕對不要上傳 GitHub（.gitignore 已經擋掉了）
#
#  ★ 移轉給老闆時，只要換這些值，程式碼一個字都不用改 ★
# ═══════════════════════════════════════════════════════════

# ── LINE ────────────────────────────────────────────────
# 從 LINE Developers Console → 你的 LINE Login channel
NEXT_PUBLIC_LIFF_ID=
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# 推播用（要另外建 Messaging API channel，跟 Login channel 放同一個 Provider）
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=

# ── Supabase ────────────────────────────────────────────
# Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ⚠️ 萬能鑰匙，只能放後端，絕對不能出現在前端程式碼
SUPABASE_SERVICE_KEY=

# ── 排程器 ──────────────────────────────────────────────
# 隨便生一串亂碼，防止別人亂打你的 cron endpoint
CRON_SECRET=
